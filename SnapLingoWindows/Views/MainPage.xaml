<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="SnapLingoWindows.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    mc:Ignorable="d">
    <Page.Resources>
        <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#19191B" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#202024" />
        <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="#29292E" />
        <SolidColorBrush x:Key="SidebarBorderBrush" Color="#19FFFFFF" />
        <SolidColorBrush x:Key="SidebarTextBrush" Color="#F5F5F5" />
        <SolidColorBrush x:Key="SidebarMutedBrush" Color="#C4C4C8" />
        <SolidColorBrush x:Key="SidebarSubtleBrush" Color="#8E8E93" />
        <SolidColorBrush x:Key="NavSelectedBackgroundBrush" Color="#30FFFFFF" />
        <SolidColorBrush x:Key="NavSelectedBorderBrush" Color="#1FFFFFFF" />
        <SolidColorBrush x:Key="NavSelectedAccentBrush" Color="#0F6CBD" />
        <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#F3F3F3" />
        <SolidColorBrush x:Key="ContentBorderBrush" Color="#12000000" />
        <SolidColorBrush x:Key="ContentPrimaryTextBrush" Color="#15171A" />
        <SolidColorBrush x:Key="ContentMutedBrush" Color="#666666" />
        <SolidColorBrush x:Key="ChipBackgroundBrush" Color="#11000000" />
        <SolidColorBrush x:Key="FieldBackgroundBrush" Color="#F7F7F7" />
        <SolidColorBrush x:Key="FieldBorderBrush" Color="#16000000" />
        <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#0F6CBD" />
        <SolidColorBrush x:Key="PrimaryAccentSoftBrush" Color="#1F0F6CBD" />

        <Style x:Key="SidebarLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{StaticResource SidebarSubtleBrush}" />
        </Style>

        <Style x:Key="PanelTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryTextBrush}" />
        </Style>

        <Style x:Key="PanelSubtitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource ContentMutedBrush}" />
        </Style>

        <Style x:Key="NavTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryTextBrush}" />
        </Style>

        <Style x:Key="SectionLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryTextBrush}" />
        </Style>

        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ContentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ContentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Foreground" Value="{StaticResource SidebarMutedBrush}" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource ShellBackgroundBrush}">
        <Grid RowDefinitions="32,*">
            <Grid
                x:Name="AppTitleBar"
                Grid.Row="0"
                Background="{StaticResource ShellBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="164" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.ColumnSpan="2"
                    BorderBrush="{StaticResource SidebarBorderBrush}"
                    BorderThickness="0,0,0,1" />

                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    Padding="12,0,0,0"
                    VerticalAlignment="Center">
                    <Border
                        Width="11"
                        Height="11"
                        Background="{StaticResource PrimaryAccentBrush}"
                        CornerRadius="4" />
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource SidebarTextBrush}"
                        Text="SnapLingo Settings" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="164" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource SidebarBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="10">
                    <Grid RowDefinitions="Auto,Auto,*,Auto">
                        <Border
                            Grid.Row="0"
                            Background="{StaticResource SidebarSurfaceBrush}"
                            BorderBrush="{StaticResource SidebarBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border
                                        Width="22"
                                        Height="22"
                                        Background="{StaticResource PrimaryAccentBrush}"
                                        CornerRadius="7">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="SL" />
                                    </Border>
                                    <StackPanel Spacing="1">
                                        <TextBlock
                                            Style="{StaticResource SidebarLabelTextStyle}"
                                            Text="SnapLingo" />
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource SidebarTextBrush}"
                                            Text="Settings" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock
                            Grid.Row="1"
                            Margin="4,10,0,6"
                            Style="{StaticResource SidebarLabelTextStyle}"
                            Text="SECTIONS" />

                        <StackPanel Grid.Row="2" Spacing="4">
                            <Button
                                x:Name="OverviewNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Overview">
                                <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="8">
                                    <Border
                                        x:Name="OverviewNavAccent"
                                        Width="4"
                                        Height="20"
                                        Background="{StaticResource NavSelectedAccentBrush}"
                                        CornerRadius="999"
                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" x:Name="OverviewNavTextBlock" Style="{StaticResource NavTitleTextStyle}" Text="Overview" />
                                </Grid>
                            </Button>

                            <Button
                                x:Name="ProviderNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Provider">
                                <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="8">
                                    <Border
                                        x:Name="ProviderNavAccent"
                                        Width="4"
                                        Height="20"
                                        Background="Transparent"
                                        CornerRadius="999"
                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" x:Name="ProviderNavTextBlock" Style="{StaticResource NavTitleTextStyle}" Text="Provider" />
                                </Grid>
                            </Button>

                            <Button
                                x:Name="HotkeyNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Hotkey">
                                <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="8">
                                    <Border
                                        x:Name="HotkeyNavAccent"
                                        Width="4"
                                        Height="20"
                                        Background="Transparent"
                                        CornerRadius="999"
                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" x:Name="HotkeyNavTextBlock" Style="{StaticResource NavTitleTextStyle}" Text="Hotkey" />
                                </Grid>
                            </Button>

                            <Button
                                x:Name="PromptNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Prompt">
                                <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="8">
                                    <Border
                                        x:Name="PromptNavAccent"
                                        Width="4"
                                        Height="20"
                                        Background="Transparent"
                                        CornerRadius="999"
                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" x:Name="PromptNavTextBlock" Style="{StaticResource NavTitleTextStyle}" Text="Prompt" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Background="{StaticResource ContentBackgroundBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
                        <Grid Padding="12">
                            <StackPanel x:Name="OverviewPanel" Spacing="10">
                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="Overview" />

                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatCardStyle}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Style="{StaticResource SidebarLabelTextStyle}" Foreground="{StaticResource ContentMutedBrush}" Text="Provider" />
                                            <TextBlock x:Name="OverviewProviderValueTextBlock" Style="{StaticResource ValueTextStyle}" Text="OpenAI" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatCardStyle}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Style="{StaticResource SidebarLabelTextStyle}" Foreground="{StaticResource ContentMutedBrush}" Text="Hotkey" />
                                            <TextBlock x:Name="OverviewHotkeyValueTextBlock" Style="{StaticResource ValueTextStyle}" Text="Ctrl + Shift + 1" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource StatCardStyle}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Style="{StaticResource SidebarLabelTextStyle}" Foreground="{StaticResource ContentMutedBrush}" Text="Storage" />
                                            <TextBlock Style="{StaticResource ValueTextStyle}" Text="Secure local" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatCardStyle}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Style="{StaticResource SidebarLabelTextStyle}" Foreground="{StaticResource ContentMutedBrush}" Text="Workflow" />
                                            <TextBlock x:Name="OverviewWorkflowValueTextBlock" Style="{StaticResource ValueTextStyle}" Text="Selection + hotkey" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Quick actions" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button x:Name="ShowPanelButton" Click="OnShowPanelClicked" Content="Show panel" />
                                            <Button x:Name="UseClipboardButton" Click="OnUseClipboardClicked" Content="Use clipboard" />
                                        </StackPanel>
                                        <TextBlock
                                            x:Name="OverviewStatusTextBlock"
                                            Foreground="{StaticResource ContentMutedBrush}"
                                            Visibility="Collapsed"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="ProviderPanel" Spacing="10" Visibility="Collapsed">
                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="Provider" />

                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Provider" />
                                        <ComboBox x:Name="ProviderComboBox" SelectionChanged="OnProviderChanged" />
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Model" />
                                        <ComboBox
                                            x:Name="ModelComboBox"
                                            PlaceholderText="Save an API key to load models"
                                            SelectionChanged="OnModelChanged" />
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="API key" />
                                        <PasswordBox x:Name="ApiKeyPasswordBox" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Click="OnSaveKeyClicked" Content="Save key" />
                                            <Button Click="OnClearKeyClicked" Content="Clear key" />
                                        </StackPanel>
                                        <TextBlock
                                            x:Name="ProviderStatusTextBlock"
                                            Foreground="{StaticResource ContentMutedBrush}"
                                            Visibility="Collapsed"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="HotkeyPanel" Spacing="10" Visibility="Collapsed">
                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="Hotkey" />

                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Preset" />
                                        <ComboBox x:Name="HotkeyComboBox" SelectionChanged="OnHotkeyChanged" />
                                        <TextBlock
                                            x:Name="HotkeyStatusTextBlock"
                                            Foreground="{StaticResource ContentMutedBrush}"
                                            Visibility="Collapsed"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="PromptPanel" Spacing="10" Visibility="Collapsed">
                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="Prompt" />

                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Prompt profile" />
                                        <ComboBox x:Name="PromptComboBox" SelectionChanged="OnPromptChanged" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button x:Name="CreatePromptButton" Click="OnCreatePromptClicked" Content="New prompt" />
                                            <Button x:Name="SavePromptButton" Click="OnSavePromptClicked" Content="Save prompt" />
                                            <Button x:Name="DeletePromptButton" Click="OnDeletePromptClicked" Content="Delete prompt" />
                                        </StackPanel>
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Name" />
                                        <TextBox x:Name="PromptNameTextBox" TextChanged="OnPromptNameChanged" />
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Translate prompt" />
                                        <TextBox
                                            x:Name="TranslatePromptTextBox"
                                            AcceptsReturn="True"
                                            Height="120"
                                            TextChanged="OnTranslatePromptChanged"
                                            TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Polish prompt" />
                                        <TextBox
                                            x:Name="PolishPromptTextBox"
                                            AcceptsReturn="True"
                                            Height="120"
                                            TextChanged="OnPolishPromptChanged"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            x:Name="PromptStatusTextBlock"
                                            Foreground="{StaticResource ContentMutedBrush}"
                                            Visibility="Collapsed"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
