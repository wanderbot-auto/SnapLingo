<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="SnapLingoWindows.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    mc:Ignorable="d">
    <Page.Resources>
        <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#19191B" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#202024" />
        <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="#29292E" />
        <SolidColorBrush x:Key="SidebarBorderBrush" Color="#19FFFFFF" />
        <SolidColorBrush x:Key="SidebarTextBrush" Color="#F5F5F5" />
        <SolidColorBrush x:Key="SidebarMutedBrush" Color="#C4C4C8" />
        <SolidColorBrush x:Key="SidebarSubtleBrush" Color="#8E8E93" />
        <SolidColorBrush x:Key="NavSelectedBackgroundBrush" Color="#30FFFFFF" />
        <SolidColorBrush x:Key="NavSelectedBorderBrush" Color="#1FFFFFFF" />
        <SolidColorBrush x:Key="NavSelectedAccentBrush" Color="#0F6CBD" />
        <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#F3F3F3" />
        <SolidColorBrush x:Key="ContentBorderBrush" Color="#12000000" />
        <SolidColorBrush x:Key="ContentPrimaryTextBrush" Color="#15171A" />
        <SolidColorBrush x:Key="ContentMutedBrush" Color="#666666" />
        <SolidColorBrush x:Key="ChipBackgroundBrush" Color="#11000000" />
        <SolidColorBrush x:Key="FieldBackgroundBrush" Color="#F7F7F7" />
        <SolidColorBrush x:Key="FieldBorderBrush" Color="#16000000" />
        <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#0F6CBD" />
        <SolidColorBrush x:Key="PrimaryAccentSoftBrush" Color="#1F0F6CBD" />

        <Style x:Key="SidebarLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{StaticResource SidebarSubtleBrush}" />
        </Style>

        <Style x:Key="PanelTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryTextBrush}" />
        </Style>

        <Style x:Key="PanelSubtitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource ContentMutedBrush}" />
        </Style>

        <Style x:Key="NavTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryTextBrush}" />
        </Style>

        <Style x:Key="SectionLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryTextBrush}" />
        </Style>

        <Style x:Key="SectionHintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource ContentMutedBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ContentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ContentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Foreground" Value="{StaticResource SidebarMutedBrush}" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccentSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryTextBrush}" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
        </Style>

        <Style x:Key="FormPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource ShellBackgroundBrush}">
        <Grid RowDefinitions="32,*">
            <Grid
                x:Name="AppTitleBar"
                Grid.Row="0"
                Background="{StaticResource ShellBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="148" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.ColumnSpan="2"
                    BorderBrush="{StaticResource SidebarBorderBrush}"
                    BorderThickness="0,0,0,1" />

                <StackPanel
                    Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    Padding="12,0,0,0"
                    VerticalAlignment="Center">
                    <Border
                        Width="11"
                        Height="11"
                        Background="{StaticResource PrimaryAccentBrush}"
                        CornerRadius="4" />
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource SidebarTextBrush}"
                        Text="SnapLingo Settings" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="148" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource SidebarBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="10">
                    <Grid RowDefinitions="Auto,Auto,*,Auto">
                        <Border
                            Grid.Row="0"
                            Background="{StaticResource SidebarSurfaceBrush}"
                            BorderBrush="{StaticResource SidebarBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border
                                        Width="22"
                                        Height="22"
                                        Background="{StaticResource PrimaryAccentBrush}"
                                        CornerRadius="7">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="SL" />
                                    </Border>
                                    <StackPanel Spacing="1">
                                        <TextBlock
                                            Style="{StaticResource SidebarLabelTextStyle}"
                                            Text="SnapLingo" />
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource SidebarTextBrush}"
                                            Text="Settings" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock
                            Grid.Row="1"
                            Margin="4,10,0,6"
                            Style="{StaticResource SidebarLabelTextStyle}"
                            Text="SECTIONS" />

                        <StackPanel Grid.Row="2" Spacing="4">
                            <Button
                                x:Name="OverviewNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Basic">
                                <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="8">
                                    <Border
                                        x:Name="OverviewNavAccent"
                                        Width="4"
                                        Height="20"
                                        Background="{StaticResource NavSelectedAccentBrush}"
                                        CornerRadius="999"
                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" x:Name="OverviewNavTextBlock" Style="{StaticResource NavTitleTextStyle}" Text="Basic" />
                                </Grid>
                            </Button>

                            <Button
                                x:Name="ProviderNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Provider">
                                <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="8">
                                    <Border
                                        x:Name="ProviderNavAccent"
                                        Width="4"
                                        Height="20"
                                        Background="Transparent"
                                        CornerRadius="999"
                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" x:Name="ProviderNavTextBlock" Style="{StaticResource NavTitleTextStyle}" Text="Provider" />
                                </Grid>
                            </Button>

                            <Button
                                x:Name="PromptNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Prompt">
                                <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="8">
                                    <Border
                                        x:Name="PromptNavAccent"
                                        Width="4"
                                        Height="20"
                                        Background="Transparent"
                                        CornerRadius="999"
                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" x:Name="PromptNavTextBlock" Style="{StaticResource NavTitleTextStyle}" Text="Prompt" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Background="{StaticResource ContentBackgroundBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
                        <Grid Padding="12">
                            <StackPanel x:Name="OverviewPanel" Spacing="10">
                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="Basic" />
                                <TextBlock
                                    Style="{StaticResource SectionHintTextStyle}"
                                    Text="Manage launch behavior and the global hotkey without leaving the main configuration flow." />

                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatCardStyle}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Style="{StaticResource SidebarLabelTextStyle}" Foreground="{StaticResource ContentMutedBrush}" Text="Provider" />
                                            <TextBlock x:Name="OverviewProviderValueTextBlock" Style="{StaticResource ValueTextStyle}" Text="OpenAI" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatCardStyle}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Style="{StaticResource SidebarLabelTextStyle}" Foreground="{StaticResource ContentMutedBrush}" Text="Hotkey" />
                                            <TextBlock x:Name="OverviewHotkeyValueTextBlock" Style="{StaticResource ValueTextStyle}" Text="Ctrl + Shift + 1" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource StatCardStyle}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Style="{StaticResource SidebarLabelTextStyle}" Foreground="{StaticResource ContentMutedBrush}" Text="Storage" />
                                            <TextBlock Style="{StaticResource ValueTextStyle}" Text="Secure local" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatCardStyle}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Style="{StaticResource SidebarLabelTextStyle}" Foreground="{StaticResource ContentMutedBrush}" Text="Workflow" />
                                            <TextBlock x:Name="OverviewWorkflowValueTextBlock" Style="{StaticResource ValueTextStyle}" Text="Selection + hotkey" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Quick actions" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="ShowPanelButton" Grid.Column="0" Click="OnShowPanelClicked" Content="Show panel" Style="{StaticResource SecondaryActionButtonStyle}" />
                                            <Button x:Name="UseClipboardButton" Grid.Column="1" Click="OnUseClipboardClicked" Content="Use clipboard" Style="{StaticResource PrimaryActionButtonStyle}" />
                                        </Grid>
                                        <TextBlock
                                            x:Name="OverviewStatusTextBlock"
                                            Foreground="{StaticResource ContentMutedBrush}"
                                            Visibility="Collapsed"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Hotkey" />
                                        <TextBlock
                                            Style="{StaticResource SectionHintTextStyle}"
                                            Text="Choose the shortcut that opens the translation panel from anywhere in Windows." />
                                        <ComboBox x:Name="HotkeyComboBox" SelectionChanged="OnHotkeyChanged" Style="{StaticResource FormComboBoxStyle}" />
                                        <TextBlock
                                            x:Name="HotkeyStatusTextBlock"
                                            Foreground="{StaticResource ContentMutedBrush}"
                                            Visibility="Collapsed"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="ProviderPanel" Spacing="10" Visibility="Collapsed">
                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="Provider" />
                                <TextBlock
                                    Style="{StaticResource SectionHintTextStyle}"
                                    Text="Connect a provider, pick the active model, and refresh the list from its API after saving your key." />

                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Provider" />
                                        <ComboBox x:Name="ProviderComboBox" SelectionChanged="OnProviderChanged" Style="{StaticResource FormComboBoxStyle}" />
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Model" />
                                        <ComboBox
                                            x:Name="ModelComboBox"
                                            PlaceholderText="Save an API key to load models"
                                            SelectionChanged="OnModelChanged"
                                            Style="{StaticResource FormComboBoxStyle}" />
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="API key" />
                                        <PasswordBox x:Name="ApiKeyPasswordBox" Style="{StaticResource FormPasswordBoxStyle}" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Click="OnSaveKeyClicked" Content="Save key" Style="{StaticResource PrimaryActionButtonStyle}" />
                                            <Button Grid.Column="1" Click="OnClearKeyClicked" Content="Clear key" Style="{StaticResource SecondaryActionButtonStyle}" />
                                        </Grid>
                                        <TextBlock
                                            x:Name="ProviderStatusTextBlock"
                                            Foreground="{StaticResource ContentMutedBrush}"
                                            Visibility="Collapsed"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="PromptPanel" Spacing="10" Visibility="Collapsed">
                                <TextBlock Style="{StaticResource PanelTitleTextStyle}" Text="Prompt" />
                                <TextBlock
                                    Style="{StaticResource SectionHintTextStyle}"
                                    Text="Switch between prompt profiles or create your own prompt set for translate and polish actions." />

                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Prompt profile" />
                                        <ComboBox x:Name="PromptComboBox" SelectionChanged="OnPromptChanged" Style="{StaticResource FormComboBoxStyle}" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="CreatePromptButton" Grid.Column="0" Click="OnCreatePromptClicked" Content="New" Style="{StaticResource SecondaryActionButtonStyle}" />
                                            <Button x:Name="SavePromptButton" Grid.Column="1" Click="OnSavePromptClicked" Content="Save" Style="{StaticResource PrimaryActionButtonStyle}" />
                                            <Button x:Name="DeletePromptButton" Grid.Column="2" Click="OnDeletePromptClicked" Content="Delete" Style="{StaticResource SecondaryActionButtonStyle}" />
                                        </Grid>
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Name" />
                                        <TextBox x:Name="PromptNameTextBox" TextChanged="OnPromptNameChanged" Style="{StaticResource FormTextBoxStyle}" />
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Translate prompt" />
                                        <TextBox
                                            x:Name="TranslatePromptTextBox"
                                            AcceptsReturn="True"
                                            Height="120"
                                            TextChanged="OnTranslatePromptChanged"
                                            Style="{StaticResource FormTextBoxStyle}"
                                            TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource SectionLabelTextStyle}" Text="Polish prompt" />
                                        <TextBox
                                            x:Name="PolishPromptTextBox"
                                            AcceptsReturn="True"
                                            Height="120"
                                            TextChanged="OnPolishPromptChanged"
                                            Style="{StaticResource FormTextBoxStyle}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            x:Name="PromptStatusTextBlock"
                                            Foreground="{StaticResource ContentMutedBrush}"
                                            Visibility="Collapsed"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
