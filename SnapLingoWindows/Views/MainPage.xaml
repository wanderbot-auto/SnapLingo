<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="SnapLingoWindows.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:infrastructure="using:SnapLingoWindows.Infrastructure"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Light"
    mc:Ignorable="d">
    <Page.Resources>
        <SolidColorBrush x:Key="TransparentBrush" Color="#00000000" />
        <SolidColorBrush x:Key="WindowBackdropBrush" Color="#F4F1EB" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1A1A1A" />
        <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="#2A2A2A" />
        <SolidColorBrush x:Key="SidebarBorderBrush" Color="#19FFFFFF" />
        <SolidColorBrush x:Key="SidebarTextBrush" Color="#E5FFFFFF" />
        <SolidColorBrush x:Key="SidebarMutedBrush" Color="#99FFFFFF" />
        <SolidColorBrush x:Key="SidebarSubtleBrush" Color="#4DFFFFFF" />
        <SolidColorBrush x:Key="SidebarNavTextBrush" Color="#C6CDD8" />
        <SolidColorBrush x:Key="SidebarNavSelectedTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="NavSelectedBackgroundBrush" Color="#14FFFFFF" />
        <SolidColorBrush x:Key="NavSelectedBorderBrush" Color="#1AFFFFFF" />
        <SolidColorBrush x:Key="NavSelectedAccentBrush" Color="#2B7FFF" />
        <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#2B7FFF" />
        <SolidColorBrush x:Key="PrimaryAccentSoftBrush" Color="#162B7FFF" />
        <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#FBFBFA" />
        <SolidColorBrush x:Key="ContentBorderBrush" Color="#CCE5E5E5" />
        <SolidColorBrush x:Key="ContentPrimaryTextBrush" Color="#171717" />
        <SolidColorBrush x:Key="ContentSecondaryTextBrush" Color="#404040" />
        <SolidColorBrush x:Key="ContentMutedBrush" Color="#737373" />
        <SolidColorBrush x:Key="FieldBackgroundBrush" Color="#FAFAFA" />
        <SolidColorBrush x:Key="FieldBorderBrush" Color="#DCDCDC" />
        <SolidColorBrush x:Key="SegmentBackgroundBrush" Color="#F3F3F3" />
        <SolidColorBrush x:Key="SegmentSelectedBorderBrush" Color="#E7E7E7" />
        <SolidColorBrush x:Key="StatusInfoBackgroundBrush" Color="#EFF6FF" />
        <SolidColorBrush x:Key="StatusInfoBorderBrush" Color="#DBEAFE" />
        <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="#ECFDF5" />
        <SolidColorBrush x:Key="SuccessBorderBrush" Color="#D1FAE5" />
        <SolidColorBrush x:Key="WindowControlHoverBrush" Color="#E9EEF8" />
        <SolidColorBrush x:Key="WindowControlHoverForegroundBrush" Color="#2852A6" />
        <SolidColorBrush x:Key="WindowCloseHoverBrush" Color="#FEE2E2" />
        <SolidColorBrush x:Key="WindowCloseHoverForegroundBrush" Color="#B42318" />

        <SvgImageSource x:Key="BasicHeaderIcon" UriSource="ms-appx:///Assets/FigmaIcons/header-basic.svg" />
        <SvgImageSource x:Key="ProviderCardIcon" UriSource="ms-appx:///Assets/FigmaIcons/card-provider.svg" />
        <SvgImageSource x:Key="HotkeyCardIcon" UriSource="ms-appx:///Assets/FigmaIcons/card-hotkey.svg" />
        <SvgImageSource x:Key="StorageCardIcon" UriSource="ms-appx:///Assets/FigmaIcons/card-storage.svg" />
        <SvgImageSource x:Key="WorkflowCardIcon" UriSource="ms-appx:///Assets/FigmaIcons/card-workflow.svg" />
        <SvgImageSource x:Key="QuickActionsIcon" UriSource="ms-appx:///Assets/FigmaIcons/quick-actions.svg" />
        <SvgImageSource x:Key="ActionPanelIcon" UriSource="ms-appx:///Assets/FigmaIcons/action-panel.svg" />
        <SvgImageSource x:Key="ActionClipboardIcon" UriSource="ms-appx:///Assets/FigmaIcons/action-clipboard.svg" />
        <SvgImageSource x:Key="HotkeyBannerIcon" UriSource="ms-appx:///Assets/FigmaIcons/hotkey-banner.svg" />
        <SvgImageSource x:Key="SidebarSyncIcon" UriSource="ms-appx:///Assets/FigmaIcons/sidebar-sync.svg" />
        <BitmapImage x:Key="BrandSidebarLogo" UriSource="ms-appx:///Assets/GeneratedLogo/logo-88.png" />
        <BitmapImage x:Key="BrandHeaderLogo" UriSource="ms-appx:///Assets/GeneratedLogo/logo-32.png" />

        <Style x:Key="SidebarLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SidebarSubtleBrush}" />
            <Setter Property="CharacterSpacing" Value="90" />
        </Style>

        <Style x:Key="SidebarNavTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <Style x:Key="PanelTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryTextBrush}" />
        </Style>

        <Style x:Key="PanelSubtitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource ContentMutedBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryTextBrush}" />
        </Style>

        <Style x:Key="SectionHintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource ContentMutedBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style x:Key="InfoLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource ContentMutedBrush}" />
        </Style>

        <Style x:Key="InfoValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryTextBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style x:Key="SurfaceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource ContentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="OverviewStatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource ContentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinHeight" Value="64" />
        </Style>

        <Style x:Key="CompactOverviewCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource ContentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinHeight" Value="58" />
        </Style>

        <Style x:Key="CardBackdropIconStyle" TargetType="Image">
            <Setter Property="Width" Value="84" />
            <Setter Property="Height" Value="84" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="0,-24,-50,0" />
            <Setter Property="Opacity" Value="0.08" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <CompositeTransform Rotation="45" ScaleX="2.15" ScaleY="2.15" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TransparentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TransparentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Foreground" Value="{StaticResource SidebarNavTextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Height" Value="36" />
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{StaticResource TransparentBrush}" />
            <Setter Property="Foreground" Value="#4B5563" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccentSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ContentPrimaryTextBrush}" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="SegmentSelectedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource SegmentSelectedBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SegmentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FormPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource TransparentBrush}">
        <Border
            Background="{StaticResource WindowBackdropBrush}"
            BorderBrush="{StaticResource TransparentBrush}"
            BorderThickness="0"
            CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="168" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="{StaticResource SidebarBackgroundBrush}"
                    BorderBrush="{StaticResource SidebarBorderBrush}"
                    BorderThickness="0,0,1,0"
                    CornerRadius="10,0,0,10"
                    Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            x:Name="SidebarDragHandle"
                            Grid.Row="0"
                            Background="{StaticResource SidebarSurfaceBrush}"
                            BorderBrush="{StaticResource SidebarBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border
                                    Width="40"
                                    Height="40"
                                    Background="#14FFFFFF"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <Image
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="26"
                                        Height="26"
                                        Source="{StaticResource BrandSidebarLogo}"
                                        Stretch="Uniform" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock
                                        x:Name="SidebarAppNameTextBlock"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource SidebarTextBrush}"
                                        Text="SnapLingo" />
                                    <TextBlock
                                        x:Name="SidebarSettingsTextBlock"
                                        Margin="0,2,0,0"
                                        FontSize="12"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource SidebarMutedBrush}"
                                        Text="Settings Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock
                            x:Name="SectionsLabelTextBlock"
                            Grid.Row="1"
                            Margin="6,12,0,8"
                            Style="{StaticResource SidebarLabelTextStyle}"
                            Text="SECTIONS" />

                        <StackPanel
                            Grid.Row="2"
                            Spacing="4">
                            <Button
                                x:Name="OverviewNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Basic">
                                <Grid ColumnDefinitions="4,16,*" Padding="0,0,8,0">
                                    <Border x:Name="OverviewNavAccent" Width="4" Height="20" Background="{StaticResource NavSelectedAccentBrush}" CornerRadius="999" VerticalAlignment="Center" />
                                    <FontIcon Grid.Column="1" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{Binding Foreground, ElementName=OverviewNavButton}" Glyph="&#xE713;" VerticalAlignment="Center" />
                                    <TextBlock x:Name="OverviewNavTextBlock" Grid.Column="2" Margin="10,0,0,0" Foreground="{Binding Foreground, ElementName=OverviewNavButton}" Style="{StaticResource SidebarNavTextStyle}" Text="Basic" VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button
                                x:Name="ProviderNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Provider">
                                <Grid ColumnDefinitions="4,16,*" Padding="0,0,8,0">
                                    <Border x:Name="ProviderNavAccent" Width="4" Height="20" Background="{StaticResource TransparentBrush}" CornerRadius="999" VerticalAlignment="Center" />
                                    <FontIcon Grid.Column="1" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{Binding Foreground, ElementName=ProviderNavButton}" Glyph="&#xF1C1;" VerticalAlignment="Center" />
                                    <TextBlock x:Name="ProviderNavTextBlock" Grid.Column="2" Margin="10,0,0,0" Foreground="{Binding Foreground, ElementName=ProviderNavButton}" Style="{StaticResource SidebarNavTextStyle}" Text="Model" VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button
                                x:Name="PromptNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Prompt">
                                <Grid ColumnDefinitions="4,16,*" Padding="0,0,8,0">
                                    <Border x:Name="PromptNavAccent" Width="4" Height="20" Background="{StaticResource TransparentBrush}" CornerRadius="999" VerticalAlignment="Center" />
                                    <FontIcon Grid.Column="1" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{Binding Foreground, ElementName=PromptNavButton}" Glyph="&#xE70F;" VerticalAlignment="Center" />
                                    <TextBlock x:Name="PromptNavTextBlock" Grid.Column="2" Margin="10,0,0,0" Foreground="{Binding Foreground, ElementName=PromptNavButton}" Style="{StaticResource SidebarNavTextStyle}" Text="Prompt" VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button
                                x:Name="AppearanceNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Appearance">
                                <Grid ColumnDefinitions="4,16,*" Padding="0,0,8,0">
                                    <Border x:Name="AppearanceNavAccent" Width="4" Height="20" Background="{StaticResource TransparentBrush}" CornerRadius="999" VerticalAlignment="Center" />
                                    <FontIcon Grid.Column="1" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{Binding Foreground, ElementName=AppearanceNavButton}" Glyph="&#xE790;" VerticalAlignment="Center" />
                                    <TextBlock x:Name="AppearanceNavTextBlock" Grid.Column="2" Margin="10,0,0,0" Foreground="{Binding Foreground, ElementName=AppearanceNavButton}" Style="{StaticResource SidebarNavTextStyle}" Text="Appearance" VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button
                                x:Name="AdvancedNavButton"
                                Click="OnNavigationClicked"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Tag="Advanced">
                                <Grid ColumnDefinitions="4,16,*" Padding="0,0,8,0">
                                    <Border x:Name="AdvancedNavAccent" Width="4" Height="20" Background="{StaticResource TransparentBrush}" CornerRadius="999" VerticalAlignment="Center" />
                                    <FontIcon Grid.Column="1" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{Binding Foreground, ElementName=AdvancedNavButton}" Glyph="&#xF14C;" VerticalAlignment="Center" />
                                    <TextBlock x:Name="AdvancedNavTextBlock" Grid.Column="2" Margin="10,0,0,0" Foreground="{Binding Foreground, ElementName=AdvancedNavButton}" Style="{StaticResource SidebarNavTextStyle}" Text="Advanced" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <Grid Grid.Row="3" ColumnSpacing="8" VerticalAlignment="Bottom">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image Width="14" Height="14" Source="{StaticResource SidebarSyncIcon}" VerticalAlignment="Top" />
                            <TextBlock
                                x:Name="SidebarFooterTextBlock"
                                Grid.Column="1"
                                FontSize="12"
                                Foreground="{StaticResource SidebarMutedBrush}"
                                Text="Stored securely on this device."
                                TextWrapping="WrapWholeWords"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Background="{StaticResource ContentBackgroundBrush}"
                    CornerRadius="0,10,10,0">
                    <Grid>
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            VerticalScrollMode="Auto">
                            <Grid Padding="16,14,16,18">
                                <StackPanel
                                    x:Name="OverviewPanel"
                                    Spacing="18">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Image Width="18" Height="18" Source="{StaticResource BrandHeaderLogo}" VerticalAlignment="Center" Stretch="Uniform" />
                                        <TextBlock x:Name="BasicTitleTextBlock" Style="{StaticResource PanelTitleTextStyle}" Text="Basic Settings" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock
                                        x:Name="BasicHintTextBlock"
                                        Style="{StaticResource PanelSubtitleTextStyle}"
                                        Text="Manage launch behavior and the global hotkey without leaving the main configuration flow."
                                        Visibility="Collapsed" />
                                </StackPanel>

                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CompactOverviewCardStyle}">
                                        <Grid>
                                            <Image Source="{StaticResource ProviderCardIcon}" Style="{StaticResource CardBackdropIconStyle}" />
                                            <StackPanel Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Image Width="14" Height="14" Source="{StaticResource ProviderCardIcon}" VerticalAlignment="Center" />
                                                    <TextBlock x:Name="BasicProviderLabelTextBlock" Style="{StaticResource InfoLabelTextStyle}" Text="Provider" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="OverviewProviderValueTextBlock" Style="{StaticResource InfoValueTextStyle}" Text="{x:Bind ViewModel.ActiveProviderDisplayName, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CompactOverviewCardStyle}">
                                        <Grid>
                                            <Image Source="{StaticResource HotkeyCardIcon}" Style="{StaticResource CardBackdropIconStyle}" />
                                            <StackPanel Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Image Width="14" Height="14" Source="{StaticResource HotkeyCardIcon}" VerticalAlignment="Center" />
                                                    <TextBlock x:Name="BasicHotkeyLabelTextBlock" Style="{StaticResource InfoLabelTextStyle}" Text="Hotkey" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="OverviewHotkeyValueTextBlock" Style="{StaticResource InfoValueTextStyle}" Text="{x:Bind ViewModel.SelectedShortcutDisplayName, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Background="{StaticResource SuccessBackgroundBrush}"
                                        BorderBrush="{StaticResource SuccessBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10"
                                        MinHeight="58">
                                        <Grid>
                                            <Image Source="{StaticResource StorageCardIcon}" Style="{StaticResource CardBackdropIconStyle}" />
                                            <StackPanel Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Image Width="14" Height="14" Source="{StaticResource StorageCardIcon}" VerticalAlignment="Center" />
                                                    <TextBlock x:Name="BasicStorageLabelTextBlock" Style="{StaticResource InfoLabelTextStyle}" Text="Storage" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="StorageValueTextBlock" Style="{StaticResource InfoValueTextStyle}" Text="{x:Bind ViewModel.StorageStatusText, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CompactOverviewCardStyle}">
                                        <Grid>
                                            <Image Source="{StaticResource WorkflowCardIcon}" Style="{StaticResource CardBackdropIconStyle}" />
                                            <StackPanel Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Image Width="14" Height="14" Source="{StaticResource WorkflowCardIcon}" VerticalAlignment="Center" />
                                                    <TextBlock x:Name="BasicWorkflowLabelTextBlock" Style="{StaticResource InfoLabelTextStyle}" Text="Workflow" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock x:Name="OverviewWorkflowValueTextBlock" Style="{StaticResource InfoValueTextStyle}" Text="{x:Bind ViewModel.WorkflowStatusText, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Border Style="{StaticResource SurfaceCardStyle}">
                                    <StackPanel Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Image Width="18" Height="18" Source="{StaticResource QuickActionsIcon}" VerticalAlignment="Center" />
                                            <TextBlock x:Name="QuickActionsLabelTextBlock" Style="{StaticResource SectionTitleTextStyle}" Text="Quick action mode" VerticalAlignment="Center" />
                                        </StackPanel>

                                        <Border Background="{StaticResource SegmentBackgroundBrush}" BorderBrush="{StaticResource ContentBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="3">
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                                                <Button x:Name="ShowPanelButton" Grid.Column="0" Click="OnShowPanelClicked" Style="{StaticResource SegmentSelectedButtonStyle}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Image Width="14" Height="14" Source="{StaticResource ActionPanelIcon}" VerticalAlignment="Center" />
                                                        <TextBlock x:Name="ShowPanelButtonTextBlock" FontSize="13" FontWeight="SemiBold" Foreground="#155DFC" Text="Show panel" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>

                                                <Button x:Name="UseClipboardButton" Grid.Column="1" Click="OnUseClipboardClicked" Style="{StaticResource SegmentButtonStyle}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Image Width="14" Height="14" Source="{StaticResource ActionClipboardIcon}" VerticalAlignment="Center" />
                                                        <TextBlock x:Name="UseClipboardButtonTextBlock" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource ContentMutedBrush}" Text="Clipboard only" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <Border Background="{StaticResource StatusInfoBackgroundBrush}" BorderBrush="{StaticResource StatusInfoBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
                                            <Grid ColumnDefinitions="28,*" ColumnSpacing="10">
                                                <Border Width="28" Height="28" Background="#DBEAFE" CornerRadius="999" VerticalAlignment="Top">
                                                    <Image Width="14" Height="14" HorizontalAlignment="Center" Source="{StaticResource HotkeyBannerIcon}" VerticalAlignment="Center" />
                                                </Border>

                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock x:Name="HotkeyBannerPrefixTextBlock" FontSize="13" FontWeight="Medium" Foreground="{StaticResource ContentSecondaryTextBrush}" Text="Current hotkey is" VerticalAlignment="Center" />
                                                        <Border Background="White" BorderBrush="{StaticResource FieldBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8,4">
                                                            <TextBlock x:Name="HotkeyKeyOneTextBlock" FontSize="12" FontWeight="Medium" Foreground="#525252" Text="Ctrl" />
                                                        </Border>
                                                        <TextBlock x:Name="HotkeyPlusOneTextBlock" FontSize="14" Foreground="{StaticResource ContentSecondaryTextBrush}" Text="+" VerticalAlignment="Center" />
                                                        <Border Background="White" BorderBrush="{StaticResource FieldBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8,4">
                                                            <TextBlock x:Name="HotkeyKeyTwoTextBlock" FontSize="12" FontWeight="Medium" Foreground="#525252" Text="Alt" />
                                                        </Border>
                                                        <TextBlock x:Name="HotkeyPlusTwoTextBlock" FontSize="14" Foreground="{StaticResource ContentSecondaryTextBrush}" Text="+" VerticalAlignment="Center" />
                                                        <Border Background="White" BorderBrush="{StaticResource FieldBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8,4">
                                                            <TextBlock x:Name="HotkeyKeyThreeTextBlock" FontSize="12" FontWeight="Medium" Foreground="#525252" Text="K" />
                                                        </Border>
                                                        <TextBlock x:Name="HotkeyPlusThreeTextBlock" FontSize="14" Foreground="{StaticResource ContentSecondaryTextBrush}" Text="+" VerticalAlignment="Center" Visibility="Collapsed" />
                                                        <Border x:Name="HotkeyKeyFourBorder" Background="White" BorderBrush="{StaticResource FieldBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8,4" Visibility="Collapsed">
                                                            <TextBlock x:Name="HotkeyKeyFourTextBlock" FontSize="12" FontWeight="Medium" Foreground="#525252" Text="Space" />
                                                        </Border>
                                                    </StackPanel>

                                                    <TextBlock
                                                        x:Name="HotkeyBannerHintTextBlock"
                                                        FontSize="12"
                                                        Foreground="{StaticResource ContentMutedBrush}"
                                                        Text="Select text and press the hotkey to open the translation or polish panel."
                                                        TextWrapping="WrapWholeWords"
                                                        Visibility="Collapsed" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <TextBlock x:Name="OverviewStatusTextBlock" Foreground="{StaticResource ContentMutedBrush}" Text="{x:Bind ViewModel.OverviewStatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" Visibility="{x:Bind ViewModel.OverviewStatusVisibility, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCardStyle}">
                                    <StackPanel Spacing="12">
                                        <StackPanel Spacing="3">
                                            <TextBlock x:Name="HotkeySectionLabelTextBlock" Style="{StaticResource SectionTitleTextStyle}" Text="Global hotkey" />
                                            <TextBlock x:Name="HotkeyHintTextBlock" Style="{StaticResource SectionHintTextStyle}" Text="Choose the shortcut that opens the translation panel from anywhere in Windows." Visibility="Collapsed" />
                                        </StackPanel>
                                        <ComboBox x:Name="HotkeyComboBox" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.HotkeySettings.ShortcutChoices, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.HotkeySettings.SelectedShortcutChoice, Mode=TwoWay}" Style="{StaticResource FormComboBoxStyle}" />
                                        <TextBlock x:Name="HotkeyStatusTextBlock" Foreground="{StaticResource ContentMutedBrush}" Text="{x:Bind ViewModel.HotkeySettings.HotkeyStatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" Visibility="{x:Bind ViewModel.HotkeySettings.HotkeyStatusVisibility, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel
                                x:Name="ProviderPanel"
                                Spacing="16"
                                Visibility="Collapsed">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{StaticResource PrimaryAccentBrush}" Glyph="&#xF1C1;" />
                                        <TextBlock x:Name="ProviderTitleTextBlock" Style="{StaticResource PanelTitleTextStyle}" Text="Model" />
                                    </StackPanel>
                                    <TextBlock
                                        x:Name="ProviderHintTextBlock"
                                        Style="{StaticResource PanelSubtitleTextStyle}"
                                        Text="Connect a provider, pick the active model, and refresh the list from its API after saving your key."
                                        Visibility="Collapsed" />
                                </StackPanel>

                                <Border Style="{StaticResource SurfaceCardStyle}">
                                    <StackPanel Spacing="12">
                                        <TextBlock x:Name="ProviderFieldLabelTextBlock" Style="{StaticResource SectionTitleTextStyle}" Text="Provider" />
                                        <ComboBox x:Name="ProviderComboBox" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.ProviderSettings.ProviderChoices, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.ProviderSettings.SelectedProviderChoice, Mode=TwoWay}" Style="{StaticResource FormComboBoxStyle}" />

                                        <TextBlock x:Name="ModelFieldLabelTextBlock" Style="{StaticResource SectionTitleTextStyle}" Text="Model" />
                                        <ComboBox x:Name="ModelComboBox" DisplayMemberPath="Label" IsEnabled="{x:Bind ViewModel.ProviderSettings.CanSelectModel, Mode=OneWay}" ItemsSource="{x:Bind ViewModel.ProviderSettings.AvailableModels, Mode=OneWay}" PlaceholderText="{x:Bind ViewModel.ProviderSettings.ModelPlaceholderText, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.ProviderSettings.SelectedModelOption, Mode=TwoWay}" Style="{StaticResource FormComboBoxStyle}" />

                                        <TextBlock x:Name="ApiKeyFieldLabelTextBlock" Style="{StaticResource SectionTitleTextStyle}" Text="API key" />
                                        <PasswordBox x:Name="ApiKeyPasswordBox" PlaceholderText="{x:Bind ViewModel.ProviderSettings.ApiKeyPlaceholder, Mode=OneWay}" Style="{StaticResource FormPasswordBoxStyle}" infrastructure:PasswordBoxBinding.BoundPassword="{x:Bind ViewModel.ProviderSettings.ApiKeyInput, Mode=TwoWay}" />

                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="SaveKeyButton" Grid.Column="0" Click="OnSaveKeyClicked" Content="Save key" Style="{StaticResource PrimaryActionButtonStyle}" />
                                            <Button x:Name="ClearKeyButton" Grid.Column="1" Click="OnClearKeyClicked" Content="Clear key" Style="{StaticResource SecondaryActionButtonStyle}" />
                                        </Grid>

                                        <TextBlock x:Name="ProviderStatusTextBlock" Foreground="{StaticResource ContentMutedBrush}" Text="{x:Bind ViewModel.ProviderSettings.ProviderStatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" Visibility="{x:Bind ViewModel.ProviderSettings.ProviderStatusVisibility, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel
                                x:Name="PromptPanel"
                                Spacing="16"
                                Visibility="Collapsed">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{StaticResource PrimaryAccentBrush}" Glyph="&#xE70F;" />
                                        <TextBlock x:Name="PromptTitleTextBlock" Style="{StaticResource PanelTitleTextStyle}" Text="Prompt" />
                                    </StackPanel>
                                    <TextBlock
                                        x:Name="PromptHintTextBlock"
                                        Style="{StaticResource PanelSubtitleTextStyle}"
                                        Text="Switch between prompt profiles or create your own prompt set for translate and polish actions."
                                        Visibility="Collapsed" />
                                </StackPanel>

                                <Border Style="{StaticResource SurfaceCardStyle}">
                                    <StackPanel Spacing="12">
                                        <TextBlock x:Name="PromptProfileLabelTextBlock" Style="{StaticResource SectionTitleTextStyle}" Text="Prompt profile" />
                                        <ComboBox x:Name="PromptComboBox" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.PromptProfiles.PromptChoices, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.PromptProfiles.SelectedPromptChoice, Mode=TwoWay}" Style="{StaticResource FormComboBoxStyle}" />

                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="CreatePromptButton" Grid.Column="0" Click="OnCreatePromptClicked" Content="New" Style="{StaticResource SecondaryActionButtonStyle}" />
                                            <Button x:Name="SavePromptButton" Grid.Column="1" Click="OnSavePromptClicked" Content="Save" IsEnabled="{x:Bind ViewModel.PromptProfiles.CanEditSelectedPrompt, Mode=OneWay}" Style="{StaticResource PrimaryActionButtonStyle}" />
                                            <Button x:Name="DeletePromptButton" Grid.Column="2" Click="OnDeletePromptClicked" Content="Delete" IsEnabled="{x:Bind ViewModel.PromptProfiles.CanDeleteSelectedPrompt, Mode=OneWay}" Style="{StaticResource SecondaryActionButtonStyle}" />
                                        </Grid>

                                        <TextBlock x:Name="PromptNameLabelTextBlock" Style="{StaticResource SectionTitleTextStyle}" Text="Name" />
                                        <TextBox x:Name="PromptNameTextBox" IsEnabled="{x:Bind ViewModel.PromptProfiles.CanEditSelectedPrompt, Mode=OneWay}" Style="{StaticResource FormTextBoxStyle}" Text="{x:Bind ViewModel.PromptProfiles.PromptEditorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock x:Name="TranslatePromptLabelTextBlock" Style="{StaticResource SectionTitleTextStyle}" Text="Translate prompt" />
                                        <TextBox x:Name="TranslatePromptTextBox" AcceptsReturn="True" Height="96" IsEnabled="{x:Bind ViewModel.PromptProfiles.CanEditSelectedPrompt, Mode=OneWay}" Style="{StaticResource FormTextBoxStyle}" Text="{x:Bind ViewModel.PromptProfiles.PromptEditorTranslate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />

                                        <TextBlock x:Name="PolishPromptLabelTextBlock" Style="{StaticResource SectionTitleTextStyle}" Text="Polish prompt" />
                                        <TextBox x:Name="PolishPromptTextBox" AcceptsReturn="True" Height="96" IsEnabled="{x:Bind ViewModel.PromptProfiles.CanEditSelectedPrompt, Mode=OneWay}" Style="{StaticResource FormTextBoxStyle}" Text="{x:Bind ViewModel.PromptProfiles.PromptEditorPolish, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />

                                        <TextBlock x:Name="PromptStatusTextBlock" Foreground="{StaticResource ContentMutedBrush}" Text="{x:Bind ViewModel.PromptProfiles.PromptStatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" Visibility="{x:Bind ViewModel.PromptProfiles.PromptStatusVisibility, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel
                                x:Name="AppearancePanel"
                                Spacing="16"
                                Visibility="Collapsed">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{StaticResource PrimaryAccentBrush}" Glyph="&#xE790;" />
                                        <TextBlock x:Name="AppearanceTitleTextBlock" Style="{StaticResource PanelTitleTextStyle}" Text="Appearance" />
                                    </StackPanel>
                                    <TextBlock
                                        x:Name="AppearanceHintTextBlock"
                                        Style="{StaticResource PanelSubtitleTextStyle}"
                                        Text="Choose the interface language. Changes apply immediately without restarting SnapLingo."
                                        Visibility="Collapsed" />
                                </StackPanel>

                                <Border Style="{StaticResource SurfaceCardStyle}">
                                    <StackPanel Spacing="12">
                                        <TextBlock x:Name="LanguageLabelTextBlock" Style="{StaticResource SectionTitleTextStyle}" Text="Language" />
                                        <ComboBox x:Name="LanguageComboBox" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.AppearanceSettings.LanguageChoices, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.AppearanceSettings.SelectedLanguageChoice, Mode=TwoWay}" Style="{StaticResource FormComboBoxStyle}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel
                                x:Name="AdvancedPanel"
                                Spacing="16"
                                Visibility="Collapsed">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontFamily="Segoe Fluent Icons" FontSize="20" Foreground="{StaticResource PrimaryAccentBrush}" Glyph="&#xF14C;" />
                                        <TextBlock x:Name="AdvancedTitleTextBlock" Style="{StaticResource PanelTitleTextStyle}" Text="Advanced" />
                                    </StackPanel>
                                    <TextBlock
                                        x:Name="AdvancedHintTextBlock"
                                        Style="{StaticResource PanelSubtitleTextStyle}"
                                        Text="Review storage, workflow, and language status for the current desktop setup."
                                        Visibility="Collapsed" />
                                </StackPanel>

                                <Grid ColumnSpacing="10" RowSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource OverviewStatCardStyle}">
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="AdvancedProviderLabelTextBlock" Style="{StaticResource InfoLabelTextStyle}" Text="Provider" />
                                            <TextBlock x:Name="AdvancedProviderValueTextBlock" Style="{StaticResource InfoValueTextStyle}" Text="{x:Bind ViewModel.ActiveProviderDisplayName, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource OverviewStatCardStyle}">
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="AdvancedModelLabelTextBlock" Style="{StaticResource InfoLabelTextStyle}" Text="Model" />
                                            <TextBlock x:Name="AdvancedModelValueTextBlock" Style="{StaticResource InfoValueTextStyle}" Text="{x:Bind ViewModel.SelectedModelId, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource OverviewStatCardStyle}">
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="AdvancedStorageLabelTextBlock" Style="{StaticResource InfoLabelTextStyle}" Text="Storage" />
                                            <TextBlock x:Name="AdvancedStorageValueTextBlock" Style="{StaticResource InfoValueTextStyle}" Text="{x:Bind ViewModel.StorageStatusText, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource OverviewStatCardStyle}">
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="AdvancedWorkflowLabelTextBlock" Style="{StaticResource InfoLabelTextStyle}" Text="Workflow" />
                                            <TextBlock x:Name="AdvancedWorkflowValueTextBlock" Style="{StaticResource InfoValueTextStyle}" Text="{x:Bind ViewModel.WorkflowStatusText, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Style="{StaticResource SurfaceCardStyle}">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <TextBlock x:Name="AdvancedCredentialLabelTextBlock" Style="{StaticResource InfoLabelTextStyle}" Text="API key" />
                                            <TextBlock x:Name="AdvancedCredentialValueTextBlock" Grid.Column="1" FontSize="13" Foreground="{StaticResource ContentSecondaryTextBrush}" Text="{x:Bind ViewModel.CredentialStatusText, Mode=OneWay}" />
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <TextBlock x:Name="AdvancedLanguageLabelTextBlock" Style="{StaticResource InfoLabelTextStyle}" Text="Language" />
                                            <TextBlock x:Name="AdvancedLanguageValueTextBlock" Grid.Column="1" FontSize="13" Foreground="{StaticResource ContentSecondaryTextBrush}" Text="{x:Bind ViewModel.SelectedLanguageLabel, Mode=OneWay}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <Border
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,12,16,0"
                            Background="#F4F4F2"
                            BorderBrush="{StaticResource ContentBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="4">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button
                                    x:Name="HideWindowButton"
                                    Click="OnHideWindowClicked"
                                    PointerEntered="OnHideWindowButtonPointerEntered"
                                    PointerExited="OnWindowButtonPointerExited"
                                    Style="{StaticResource TitleBarButtonStyle}">
                                    <FontIcon FontFamily="Segoe Fluent Icons" FontSize="11" Glyph="&#xE921;" />
                                </Button>

                                <Button
                                    x:Name="CloseWindowButton"
                                    Click="OnCloseWindowClicked"
                                    PointerEntered="OnCloseWindowButtonPointerEntered"
                                    PointerExited="OnWindowButtonPointerExited"
                                    Style="{StaticResource TitleBarButtonStyle}">
                                    <FontIcon FontFamily="Segoe Fluent Icons" FontSize="11" Glyph="&#xE8BB;" />
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
